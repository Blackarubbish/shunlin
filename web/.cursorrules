```

## 常见模式和最佳实践

### 1. 列表页面模式
```typescript
// 状态管理
const [params, setParams] = useState<PostListParams>({ pageNum: 1, pageSize: 10 });

// 数据获取
const { data, isLoading } = useQuery({
  queryKey: ['posts', params],
  queryFn: () => postsApi.getPosts(params),
});

// 表格渲染
<Table
  dataSource={data?.items}
  loading={isLoading}
  pagination={{
    current: params.pageNum,
    pageSize: params.pageSize,
    total: data?.total,
    onChange: (page, pageSize) => setParams({ ...params, pageNum: page, pageSize }),
  }}
/>
```

### 2. 编辑器模式（创建/编辑）
```typescript
// 根据 URL 判断模式
const { id } = useParams();
const mode = id ? 'edit' : 'create';

// 编辑模式加载数据
const { data: post } = useQuery({
  queryKey: ['post', id],
  queryFn: () => postsApi.getOnePost(Number(id)),
  enabled: mode === 'edit' && !!id,
});

// 使用不同的 Mutation
const createMutation = useMutation({ mutationFn: postsApi.createPost });
const updateMutation = useMutation({ mutationFn: postsApi.updatePost });
```

### 3. Drawer/Modal 模式
```typescript
// 状态管理
const [drawerOpts, setDrawerOpts] = useState<{
  open: boolean;
  type: 'create' | 'edit';
  record?: Post;
}>({ open: false, type: 'create' });

// 打开 Drawer
const handleOpenDrawer = (type: 'create' | 'edit', record?: Post) => {
  setDrawerOpts({ open: true, type, record });
};
```

